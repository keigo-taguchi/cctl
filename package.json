{
  "name": "@ketaguchi0722/cctl",
  "version": "0.3.0",
  "description": "Session manager CLI for Claude Code — monitor, list, resume, search and clean up sessions",
  "type": "module",
  "bin": {
    "cctl": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "session",
    "anthropic"
  ],
  "license": "MIT",
  "author": "Keigo Taguchi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keigo-taguchi/cctl.git"
  },
  "bugs": {
    "url": "https://github.com/keigo-taguchi/cctl/issues"
  },
  "homepage": "https://github.com/keigo-taguchi/cctl#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "string-width": "^8.2.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
